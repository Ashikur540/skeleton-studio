# Skeleton Studio — environment variables
# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env
#
# All vars are prefixed NEXT_PUBLIC_ and are exposed to the browser.
# There are NO server-side secrets — the app runs fully client-side.

# App version shown in the UI footer. Keep in sync with package.json "version".
NEXT_PUBLIC_PROJECT_VERSION=0.1.0

# Canonical site URL. Used for absolute URLs / OG metadata.
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Microsoft Clarity analytics project ID. Optional — leave blank to disable.
# Get one at https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
